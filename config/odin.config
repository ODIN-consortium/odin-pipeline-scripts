/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf-core/taxprofiler Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Specific config options for ODIN
----------------------------------------------------------------------------------------
*/



profiles {
 
    odin {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
        docker.runOptions       = '-u $(id -u):$(id -g)'
		executor.name           = 'local'
        executor.cpus           = 4
        executor.memory         = 16.GB
        process {
            resourceLimits = [
                memory: 16.GB,
                cpus  : 4,
                time  : 1.h
            ]
        }
    }
    // Profile for epi2me-labs pipelines (wf-metagenomics, etc.).
    // Mounts the NORCE self-signed CA cert into the container so that wget/curl
    // can verify HTTPS connections. Falls back gracefully if CURL_CA_BUNDLE is unset.
    epi2me {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)' +
            (System.getenv('CURL_CA_BUNDLE')
                ? " -v ${System.getenv('CURL_CA_BUNDLE')}:/tmp/norce_ca.crt" +
                  " -e SSL_CERT_FILE=/tmp/norce_ca.crt" +
                  " -e CURL_CA_BUNDLE=/tmp/norce_ca.crt"
                : '')
    }

    odin_big {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
        docker.runOptions       = '-u $(id -u):$(id -g)'
		executor.name           = 'local'
        executor.cpus           = 16
        executor.memory         = 31.GB
        process {
            resourceLimits = [
                memory: 31.GB,
                cpus  : 16,
                time  : 3.h
            ]
        }
    }

}

